APP_URL=https://your-project.vercel.app

# Supadata
SUPADATA_API_KEY=your_supadata_api_key

# Shared bearer token for MCP access. For future multi-token support, you can
# provide a comma-separated list in MCP_BEARER_TOKENS instead.
MCP_BEARER_TOKEN=replace_with_a_long_random_secret
MCP_BEARER_TOKENS=

# Optional Upstash Redis for persistent rate limiting and digest logging.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Daily digest email
RESEND_API_KEY=
DIGEST_EMAIL_TO=you@example.com
DIGEST_EMAIL_FROM=YouTube MCP <onboarding@resend.dev>
DIGEST_TIMEZONE=Asia/Kolkata

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW=1 d
